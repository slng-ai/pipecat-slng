OPENAI_API_KEY=XXXXX
OPENAI_MODEL=gpt-4.1
SLNG_API_KEY=XXX

# Optional model routing (default to SLNG-hosted slng/... routes):
# SLNG_STT_MODEL=slng/deepgram/nova:3-en
# SLNG_TTS_MODEL=slng/deepgram/aura:2-en
# SLNG_TTS_VOICE=aura-2-thalia-en

# Optional BYOK: your own provider key, forwarded upstream so the provider bills
# you. Distinct from SLNG_API_KEY. Only valid on an external route (a model
# string without the slng/ prefix). https://docs.slng.ai/execution-layer/byok
# SLNG_PROVIDER_KEY=XXX
